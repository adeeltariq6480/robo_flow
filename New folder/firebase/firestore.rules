rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // No-auth mode: app runs without login. Server actions and the Python
    // worker use the Firebase Admin SDK (which bypasses these rules anyway).
    // Client-side access is open so the UI works without authentication.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
