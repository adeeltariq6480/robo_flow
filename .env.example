# Copy to .env.local (Next.js does NOT load this file automatically)

# ─── Option A: Local Firebase Emulators (no Google account needed) ───
# Run: npm run emulators   then   npm run dev
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_PROJECT_ID=label-ai-local
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=label-ai-local.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo
FIREBASE_PROJECT_ID=label-ai-local
FIREBASE_STORAGE_BUCKET=label-ai-local.appspot.com
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# ─── Option B: Real Firebase project (from Firebase Console) ───
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_SERVICE_ACCOUNT_JSON=   (optional for local dev with open rules; required for Python worker + production)

# Python YOLO worker
NEXT_PUBLIC_WORKER_API_URL=http://localhost:8000
WORKER_URL=http://localhost:8000
WORKER_API_KEY=dev-worker-key

# Google Sheets Stock Check integration (Railway worker only)
# Preferred no-service-account option: deploy scripts/google_sheets_web_app.gs
GOOGLE_SHEETS_WEB_APP_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
# Optional fallback when a service account is available:
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
STOCK_SPREADSHEET_ID=1XsLLOsz1zuj52NY1eWp6MduzYoFIaZLLTXL4GaMTqZY
