# ---------------------------------------------------------------------------
# Robo Flow frontend (Next.js) environment
# Copy to .env.local. The frontend talks ONLY to the FastAPI backend and holds
# NO secrets (no Firebase keys, no Hugging Face token).
# ---------------------------------------------------------------------------

# URL of the Python FastAPI backend
NEXT_PUBLIC_WORKER_API_URL=http://localhost:8000

# Optional — only if your Railway backend has WORKER_API_KEY set.
# Server-side only (do NOT use NEXT_PUBLIC_). Must match Railway exactly.
# Leave unset for open no-auth mode (recommended).
# WORKER_API_KEY=dev-worker-key
