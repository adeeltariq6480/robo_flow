{
  "name": "robo-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev",
    "dev:fresh": "node scripts/clean.mjs && next dev",
    "dev:clean": "node scripts/clean.mjs && next dev",
    "dev:turbo": "next dev --turbopack",
    "clean": "node scripts/clean.mjs",
    "rebuild": "npm run clean && npm run build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "emulators": "firebase emulators:start --only auth,firestore,storage --project label-ai-local",
    "dev:emulator": "node scripts/dev-with-emulator.mjs",
    "check:firebase": "node scripts/check-firebase.mjs",
    "sync:vercel": "node scripts/sync-vercel-env.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "jose": "5.9.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "firebase-tools": "^14.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
